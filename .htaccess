RewriteEngine On

# ---------------------------------------------------------------------------
# IR launch — hidden pages (server-side 301, no JS flash)
# Keep in sync with src/constants/ir-feature-flags.js
# Remove or comment out each rule when the matching flag is set to true.
# ---------------------------------------------------------------------------
RewriteRule ^investor-relations/stock-info/?$ /investor-relations [R=301,L,NC]
RewriteRule ^investor-relations/stock-info/stock-quote/?$ /investor-relations [R=301,L,NC]
RewriteRule ^investor-relations/stock-info/analyst-coverage/?$ /investor-relations [R=301,L,NC]
RewriteRule ^investor-relations/financials/quarterly-results/?$ /investor-relations/financials/sec-filings [R=301,L,NC]
RewriteRule ^investor-relations/governance/documents-and-charters/?$ /investor-relations/governance/board-of-directors [R=301,L,NC]
RewriteRule ^investor-relations/governance/?$ /investor-relations/governance/board-of-directors [R=301,L,NC]

# Hub redirects (avoid JS-only redirect pages being indexed)
RewriteRule ^investor-relations/financials/?$ /investor-relations/financials/sec-filings [R=301,L,NC]
RewriteRule ^investor-relations/news/?$ /investor-relations/news/press-releases [R=301,L,NC]
RewriteRule ^investor-relations/resources/?$ /investor-relations/resources/investor-faqs [R=301,L,NC]

# Legacy SGX announcement URLs (typo route annountcement → company-announcement)
# Keep in sync with next.config.js redirects
RewriteRule ^annountcement\.html$ /company-announcement [R=301,L,NC]
RewriteRule ^annountcement/(.+)\.html$ /company-announcement/$1 [R=301,L,NC]
RewriteRule ^annountcement/?$ /company-announcement [R=301,L,NC]
RewriteRule ^annountcement/(.+)$ /company-announcement/$1 [R=301,L,NC]

# Redirect legacy product URL to new slug (static export + Apache hosting)
RewriteRule ^verticals/metalens-foundry/iot-metalens-color-camera/?$ /verticals/metalens-products/development-kits/iot-rectangular-metalens-color-camera [R=301,L,NC]

# Canonicalize development-kits products to nested URL
RewriteRule ^verticals/metalens-foundry/iot-rectangular-metalens-color-camera/?$ /verticals/metalens-products/development-kits/iot-rectangular-metalens-color-camera [R=301,L,NC]
RewriteRule ^verticals/metalens-foundry/3d-biometrics-metalens-sensor/?$ /verticals/metalens-products/development-kits/3d-biometrics-metalens-sensor [R=301,L,NC]

RewriteRule ^/verticals/metalens-foundry/color-imaging-meta-lens / [R=301,L,NC]
RewriteRule ^/verticals/metalens-foundry/ultra-wide-fov-metalens-monochromatic-ir-camera / [R=301,L,NC]




# 1) Serve real files as-is.
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2) Serve real directories only when they have index.html.
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^ - [L]

# 3) For extensionless URLs (any depth), serve matching .html file.
# Example: /about-us -> /about-us.html
# Example: /verticals/metalens-products/development-kits -> /verticals/metalens-products/development-kits.html
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# 4) Also support exported folder format with index.html (if present).
# Example: /news/some-slug -> /news/some-slug/index.html
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.+?)/?$ /$1/index.html [L]