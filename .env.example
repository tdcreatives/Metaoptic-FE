# =============================================================================
# Environment variables — copy to .env and fill in real values
# =============================================================================

NODE_ENV=production
NEXT_PUBLIC_MOD=production

# -----------------------------------------------------------------------------
# B2I (Investor Relations — press releases, stock quote, SEC filings)
# https://www.b2i.us — credentials from B2i / client
# -----------------------------------------------------------------------------
NEXT_PUBLIC_B2I_BIZ_ID=3135
NEXT_PUBLIC_B2I_API_KEY=your_b2i_api_key_here
NEXT_PUBLIC_B2I_SYMBOL=MOT

# -----------------------------------------------------------------------------
# Main site — Contact Us (/contact-us)
# Create access key at https://web3forms.com
# Set recipient inbox in Web3Forms dashboard (e.g. sales@metaoptics.com.sg)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WEB3FORMS_ACCESS_TOKEN=your_main_site_web3forms_access_key_here
NEXT_PUBLIC_SUBJECT=New Enquiry from Metaoptic
NEXT_PUBLIC_REPLY_TO=sales@metaoptics.com.sg
NEXT_PUBLIC_REDIRECT_URL=

# -----------------------------------------------------------------------------
# Investor Relations — Web3Forms (separate access key from main site)
# Create a second form/key at https://web3forms.com
# Set recipient inbox to MOT@gateway-grp.com in Web3Forms dashboard
#
# Used by:
#   - /investor-relations/resources/contact-us  (IR-01)
#   - /investor-relations/resources/email-alerts (IR-02)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_IR_WEB3FORMS_ACCESS_KEY=your_ir_web3forms_access_key_here
NEXT_PUBLIC_IR_CONTACT_EMAIL=MOT@gateway-grp.com
NEXT_PUBLIC_IR_CONTACT_SUBJECT=MetaOptics IR - Investor Contact
NEXT_PUBLIC_IR_EMAIL_ALERTS_SUBJECT=MetaOptics IR - Email Alert Subscription
